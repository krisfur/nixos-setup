# Ghostty configuration.
# window-width/height are in terminal cells (columns/rows), not pixels.
# The default landed at 79x28, one column short of btop's 80x28 minimum.

font-family = JetBrainsMono Nerd Font
font-size = 11

# nordfox palette inlined (the higher-contrast, more saturated take on Nord
# that matches the neovim colourscheme). Inlined rather than `theme = nordfox`
# because not every ghostty build bundles that scheme yet.
palette = 0=#3b4252
palette = 1=#bf616a
palette = 2=#a3be8c
palette = 3=#ebcb8b
palette = 4=#81a1c1
palette = 5=#b48ead
palette = 6=#88c0d0
palette = 7=#e5e9f0
palette = 8=#53648d
palette = 9=#d06f79
palette = 10=#b1d196
palette = 11=#f0d399
palette = 12=#8cafd2
palette = 13=#c895bf
palette = 14=#93ccdc
palette = 15=#e7ecf4
background = #2e3440
foreground = #cdcecf
cursor-color = #cdcecf
cursor-text = #2e3440
selection-background = #3e4a5b
selection-foreground = #cdcecf

# Slight translucency for an ephemeral feel. labwc has no compositor blur,
# so this is plain alpha over whatever is behind the window.
background-opacity = 0.93

window-width = 110
window-height = 32

# No client-side decorations. ghostty defaults to `auto`, which (with labwc
# forcing CSD via serverDecoration="no") makes libadwaita draw a thin CSD edge
# that only shows up in the *tiled* state - the stray dashed line at the top
# when snapping with Meta+Up/Down. `none` removes that surface entirely.
window-decoration = none
