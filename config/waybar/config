{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 4,

    "modules-left": ["ext/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "bluetooth", "group/hardware", "pulseaudio", "custom/power-profile", "battery", "custom/notification", "custom/power"],

    "ext/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "sort-by-id": true,
        "format-icons": {
            "active": "َ°®¯",
            "default": "َ°ٹ "
        }
    },

    "clock": {
        "format": "َ±‘‚ {:%H:%M}",
        "format-alt": "َ°ƒ­ {:%Y-%m-%d}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    },

    "bluetooth": {
        "format": "َ°‚¯ {status}",
        "format-connected": "َ°‚± {device_alias}",
        "format-connected-battery": "َ°‚± {device_alias} {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
        "on-click": "ghostty --class=com.app.bluetuith --gtk-single-instance=false -e bluetuith"
    },

    "cpu": {
        "format": " {usage}% ",
        "interval": 2,
        "on-click": "ghostty --class=com.app.btop --gtk-single-instance=false -e btop"
    },

    "memory": {
        "format": "َ°‘­ {used:0.1f}G/{total:0.1f}G",
        "interval": 5,
        "on-click": "ghostty --class=com.app.btop --gtk-single-instance=false -e btop"
    },

    "group/hardware": {
        "orientation": "horizontal",
        "modules": [
            "cpu",
            "memory"
        ]
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں Muted",
        "format-icons": {
            "headphone": "َ°‹‹",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "pavucontrol"
    },

    "custom/power-profile": {
        "interval": 2,
        "return-type": "json",
        "exec": "bash -lc 'profile=$(powerprofilesctl get 2>/dev/null || echo balanced); case \"$profile\" in power-saver) printf \"{\\\"text\\\":\\\"ًںŒ؟\\\",\\\"class\\\":\\\"power-saver\\\",\\\"tooltip\\\":\\\"Power profile: power-saver\\\"}\\n\" ;; balanced) printf \"{\\\"text\\\":\\\"âک¯ï¸ژ\\\",\\\"class\\\":\\\"balanced\\\",\\\"tooltip\\\":\\\"Power profile: balanced\\\"}\\n\" ;; performance) printf \"{\\\"text\\\":\\\"ًںڑ€\\\",\\\"class\\\":\\\"performance\\\",\\\"tooltip\\\":\\\"Power profile: performance\\\"}\\n\" ;; *) printf \"{\\\"text\\\":\\\"âڑ،\\\",\\\"class\\\":\\\"unknown\\\",\\\"tooltip\\\":\\\"Power profile: %s\\\"}\\n\" \"$profile\" ;; esac'",
        "on-click": "bash -lc 'current=$(powerprofilesctl get 2>/dev/null || echo balanced); case \"$current\" in power-saver) next=balanced ;; balanced) next=performance ;; performance) next=power-saver ;; *) next=balanced ;; esac; powerprofilesctl set \"$next\"'",
        "on-click-right": "bash -lc 'choice=$(printf \"ًںڑ€ performance\\nâک¯ï¸ژ balanced\\nًںŒ؟ power-saver\" | fuzzel --dmenu --hide-prompt --lines 3); case \"$choice\" in *performance) powerprofilesctl set performance ;; *balanced) powerprofilesctl set balanced ;; *power-saver) powerprofilesctl set power-saver ;; *) : ;; esac'"
    },

    "battery": {
        "interval": 2,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "tooltip-format-discharging": "{timeTo}\nâ†“ {power:.1f} W",
        "tooltip-format-charging": "{timeTo}\nâ†‘ {power:.1f} W",
        "tooltip-format": "{timeTo}\n{power:.1f} W"
    },

    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "َ±…«",
            "none": "َ°‚ڑ",
            "dnd-notification": "َ±ڈ§",
            "dnd-none": "َ±ڈ§",
            "inhibited-notification": "َ±…«",
            "inhibited-none": "َ°‚ڑ",
            "dnd-inhibited-notification": "َ±ڈ§",
            "dnd-inhibited-none": "َ±ڈ§"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    "custom/power": {
        "tooltip": true,
        "format": "âڈ»",
        "tooltip-format": "Power menu",
        "on-click": "bash -lc 'choice=$(printf \"َ°گ¥ Shutdown\\nَ°œ‰ Reboot\\nَ°…– Cancel\" | fuzzel --dmenu --hide-prompt --lines 3); case \"$choice\" in \"َ°گ¥ Shutdown\") systemctl poweroff ;; \"َ°œ‰ Reboot\") systemctl reboot ;; *) : ;; esac'"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 10
    }
}
